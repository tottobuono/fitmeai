# =============================================================================
# Fitme.ai — variabili d'ambiente (template)
#
# Copia in `.env` e adatta i valori: `cp .env.example .env`
# NON committare mai `.env` (è in .gitignore). Niente segreti reali qui dentro.
# =============================================================================

# --- Ambiente ---
ENV=local                       # local | staging | production

# --- PostgreSQL ---
POSTGRES_USER=fitme
POSTGRES_PASSWORD=change-me-in-local
POSTGRES_DB=fitme
POSTGRES_PORT=5432
# DSN usato da apps/api e workers/tryon (host=localhost da fuori Docker)
DATABASE_URL=postgresql://fitme:change-me-in-local@localhost:5432/fitme

# --- Redis (coda job async) ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# --- Storage S3-compatibile (MinIO in locale, bucket EU in produzione) ---
STORAGE_ENDPOINT=http://localhost:9000   # endpoint S3 (MinIO in locale)
STORAGE_REGION=eu-central-1              # regione EU-first
STORAGE_BUCKET=fitme-assets
STORAGE_ACCESS_KEY=fitme-minio
STORAGE_SECRET_KEY=change-me-in-local
STORAGE_PORT=9000                        # porta API S3 (host)
STORAGE_CONSOLE_PORT=9001                # porta console MinIO (host)
# Durata (secondi) degli URL firmati per accesso agli asset
STORAGE_SIGNED_URL_TTL=300

# --- Virtual try-on provider ---
# Provider attivo dietro l'astrazione interna. In Fase 1 usiamo 'mock'.
TRYON_PROVIDER=mock                      # mock | fashn | fal | ...
# Chiavi dei provider reali: lasciare vuote finché non si integra (Fase 2)
TRYON_API_KEY=

# --- API / app ---
API_PORT=8000
# Origini autorizzate per CORS (frontend), separate da virgola
CORS_ALLOW_ORIGINS=http://localhost:3000

# --- Logging ---
# Mai loggare immagini, misure in chiaro o identificativi inutili (privacy by design).
LOG_LEVEL=info                           # debug | info | warning | error
